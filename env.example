# ─── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Comma-separated Telegram user IDs who have admin access
ADMIN_IDS=123456789,987654321

# ─── Flask API ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5000

# Public-facing URL sent to admins as the activation endpoint
# Replace with your server IP or domain
API_BASE_URL=http://YOUR_SERVER_IP:5000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=data/license_bot.db

# ─── Bot Settings ─────────────────────────────────────────────────────────────
CHANNEL_URL=https://t.me/your_channel
SUPPORT_USERNAME=@Emad_Habibnia

# Notification check interval in seconds (default: 3600 = 1 hour)
NOTIFICATION_INTERVAL=3600
